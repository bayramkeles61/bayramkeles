---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
    <div class="container-outer mt-16 sm:mt-32">
        <div class="container-outer-inner">
            <div class="container-inner">
                <div class="container-inner-content max-w-3xl">
                    <article>
                        <!-- Header -->
                        <header class="flex flex-col">
                            <a
                                href="/en/blog"
                                class="group mb-8 flex items-center text-sm font-medium text-text-muted transition hover:text-teal"
                            >
                                <svg
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    class="mr-2 h-4 w-4 stroke-current transition group-hover:-translate-x-0.5"
                                >
                                    <path
                                        d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
                                        stroke-width="1.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                </svg>
                                all posts
                            </a>
                            <time
                                datetime={post.data.pubDate.toISOString()}
                                class="order-first flex items-center text-base text-text-muted"
                            >
                                <span
                                    class="h-4 w-0.5 rounded-full bg-border mr-3"
                                ></span>
                                {
                                    post.data.pubDate.toLocaleDateString(
                                        "en-US",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )
                                }
                            </time>
                            <h1
                                class="mt-6 text-4xl font-bold tracking-tight text-text sm:text-5xl"
                            >
                                {post.data.title}
                            </h1>
                        </header>

                        <!-- Content -->
                        <div class="mt-8 prose">
                            <Content />
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
