---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SimplePageLayout from "../../layouts/SimplePageLayout.astro";
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "../../i18n/utils";

interface Props {
    lang: "tr" | "en";
}

const { lang } = Astro.props;

// Filter posts if needed. Assuming shared content for now, or filtered by lang property in frontmatter later.
// Currently fetching all non-draft posts.
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) => {
    return date.toLocaleDateString(lang === "tr" ? "tr-TR" : "en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
};

const title = "Blog";
const description = lang === "tr" ? "Yazılarım." : "My writings.";
const pageTitle = lang === "tr" ? "Yazdıklarım" : "writings";
const pageIntro =
    lang === "tr"
        ? "Düşüncelerim, öğrendiklerim ve deneyimlerim hakkında."
        : "On my thoughts, learnings and experiences.";
const readMoreText = lang === "tr" ? "yazıyı oku" : "read article";
const noPostsText =
    lang === "tr"
        ? "Henüz yazı yok. Yakında gelecek!"
        : "No posts yet. Coming soon!";
---

<SimplePageLayout
    title={title}
    description={description}
    pageTitle={pageTitle}
    pageIntro={pageIntro}
>
    <!-- Header Action (RSS Button) -->
    <a
        slot="header-action"
        href="/rss.xml"
        class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm font-medium text-zinc-900 transition hover:border-teal-500 hover:text-teal-500 dark:border-zinc-700/40 dark:bg-zinc-800 dark:text-zinc-100 dark:hover:border-teal-400 dark:hover:text-teal-400 shrink-0"
    >
        <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12.75 19.5v-.75a7.5 7.5 0 0 0-7.5-7.5H4.5m0-6.75h.75c7.87 0 14.25 6.38 14.25 14.25v.75M6 18.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"
            ></path>
        </svg>
        RSS
    </a>

    <!-- Posts List -->
    {
        posts.length > 0 ? (
            <div class="md:border-l md:border-zinc-100 dark:md:border-zinc-700/40 md:pl-6">
                <div class="flex max-w-3xl flex-col space-y-16">
                    {posts.map((post) => (
                        <article class="md:grid md:grid-cols-4 md:items-baseline">
                            <div class="md:col-span-3 group relative flex flex-col items-start">
                                <h2 class="text-base font-semibold tracking-tight text-zinc-800 dark:text-zinc-100">
                                    <div class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 bg-zinc-50 dark:bg-zinc-800/50 opacity-0 transition group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 sm:rounded-2xl" />
                                    <a
                                        href={getRelativeLocaleUrl(
                                            lang,
                                            `blog/${post.slug}`,
                                        )}
                                    >
                                        <span class="absolute -inset-x-4 -inset-y-6 z-20 sm:-inset-x-6 sm:rounded-2xl" />
                                        <span class="relative z-10">
                                            {post.data.title}
                                        </span>
                                    </a>
                                </h2>
                                <time class="md:hidden relative z-10 order-first mb-3 flex items-center text-sm text-zinc-400 dark:text-zinc-500 pl-3.5">
                                    <span
                                        class="absolute inset-y-0 left-0 flex items-center"
                                        aria-hidden="true"
                                    >
                                        <span class="h-4 w-0.5 rounded-full bg-zinc-200 dark:bg-zinc-500" />
                                    </span>
                                    {formatDate(post.data.pubDate)}
                                </time>
                                {post.data.description && (
                                    <p class="relative z-10 mt-2 text-sm text-zinc-600 dark:text-zinc-400">
                                        {post.data.description}
                                    </p>
                                )}
                                <div class="relative z-10 mt-4 flex items-center text-sm font-medium text-teal-500">
                                    {readMoreText}
                                    <svg
                                        viewBox="0 0 16 16"
                                        fill="none"
                                        class="ml-1 h-4 w-4 stroke-current"
                                    >
                                        <path
                                            d="M6.75 5.75 9.25 8l-2.5 2.25"
                                            stroke-width="1.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        />
                                    </svg>
                                </div>
                            </div>
                            <time class="mt-1 hidden md:block relative z-10 order-first mb-3 text-sm text-zinc-400 dark:text-zinc-500">
                                {formatDate(post.data.pubDate)}
                            </time>
                        </article>
                    ))}
                </div>
            </div>
        ) : (
            <div class="text-center py-16">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-zinc-100 dark:bg-zinc-800 mb-4">
                    <span class="text-3xl">✍️</span>
                </div>
                <p class="text-zinc-400 dark:text-zinc-500">{noPostsText}</p>
            </div>
        )
    }
</SimplePageLayout>
