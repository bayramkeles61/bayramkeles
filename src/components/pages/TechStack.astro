---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SimplePageLayout from "../../layouts/SimplePageLayout.astro";
import { getCollection } from "astro:content";

interface Props {
    lang: "tr" | "en";
}

const { lang } = Astro.props;

const techStackData = await getCollection("tech-stack");
const techStack = techStackData[0]?.data || [];

// Group by category
const categories: Record<string, any[]> = {};
techStack.forEach((tech: any) => {
    if (!categories[tech.category]) {
        categories[tech.category] = [];
    }
    categories[tech.category].push(tech);
});

const categoryConfig: Record<string, { label: string; icon: string }> = {
    language: {
        label: lang === "tr" ? "diller" : "languages",
        icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" /></svg>',
    },
    frontend: {
        label: "frontend",
        icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" /></svg>',
    },
    backend: {
        label: "backend",
        icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" /></svg>',
    },
    database: {
        label: lang === "tr" ? "veritabanı" : "database",
        icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>',
    },
    devops: {
        label: "devops",
        icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" /></svg>',
    },
    tools: {
        label: lang === "tr" ? "araçlar" : "tools",
        icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>',
    },
};

const title = "Tech Stack";
const description =
    lang === "tr" ? "Kullandığım teknolojiler." : "Technologies I use.";
const pageTitle =
    lang === "tr"
        ? "Kullandığım araçlar ve sevdiğim teknolojiler."
        : "Tools I use and technologies I love.";
const pageIntro =
    lang === "tr"
        ? "Yazılım geliştirirken kullandığım diller, framework'ler ve araçlar. Her birinin bir öğrenme hikayesi var."
        : "Languages, frameworks and tools I use when developing software. Each has a learning story.";

const noTechText =
    lang === "tr" ? "Henüz teknoloji eklenmedi." : "No technology added yet.";
---

<SimplePageLayout
    title={title}
    description={description}
    pageTitle={pageTitle}
    pageIntro={pageIntro}
>
    <div class="space-y-20">
        {
            Object.entries(categories).map(([key, items]) => (
                <section class="md:border-l md:border-zinc-100 dark:md:border-zinc-700/40 md:pl-6">
                    <div class="grid max-w-3xl grid-cols-1 gap-y-8 md:grid-cols-4">
                        <h2 class="flex items-center gap-3 text-sm font-semibold text-zinc-900 dark:text-zinc-100">
                            <span
                                class="text-teal-500"
                                set:html={
                                    categoryConfig[key]?.icon ||
                                    categoryConfig.tools.icon
                                }
                            />
                            {categoryConfig[key]?.label || key}
                        </h2>
                        <div class="md:col-span-3">
                            <ul class="space-y-4 list-none p-0">
                                {items.map((tech: any) => (
                                    <li class="flex flex-col gap-1 rounded-xl p-4 -m-4 transition-colors hover:bg-zinc-50 dark:hover:bg-zinc-800/50">
                                        <span class="font-medium text-zinc-800 dark:text-zinc-100">
                                            {tech.name}
                                        </span>
                                        {tech.description && (
                                            <span class="text-sm text-zinc-500 dark:text-zinc-400">
                                                {tech.description}
                                            </span>
                                        )}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                </section>
            ))
        }
    </div>

    {
        Object.keys(categories).length === 0 && (
            <div class="mt-16 text-center py-16">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-zinc-100 dark:bg-zinc-800 mb-4">
                    <span class="text-3xl">⚙️</span>
                </div>
                <p class="text-zinc-400 dark:text-zinc-500">{noTechText}</p>
            </div>
        )
    }
</SimplePageLayout>
