---
import SimplePageLayout from "../../layouts/SimplePageLayout.astro";

import { getCollection } from "astro:content";
import { useTranslations, getRelativeLocaleUrl } from "../../i18n/utils";

interface Props {
    lang: "tr" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get latest blog posts
const allPosts = await getCollection("blog", ({ data }) => {
    return !data.draft;
});

const latestPosts = allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

// Photo gallery placeholders
const photos = [
    { alt: "Fotoğraf 1", emoji: "🎬" },
    { alt: "Fotoğraf 2", emoji: "🎮" },
    { alt: "Fotoğraf 3", emoji: "📷" },
    { alt: "Fotoğraf 4", emoji: "💻" },
    { alt: "Fotoğraf 5", emoji: "🎵" },
];

const pageTitle = lang === "tr" ? "Ön Yüz Geliştirici" : "Frontend Developer";
---

<SimplePageLayout
    title={lang === "tr" ? "Ana Sayfa" : "Home"}
    description={lang === "tr"
        ? "Bayram Keleş - Yazılım geliştirici, film ve oyun tutkunu."
        : "Bayram Keleş - Software Developer."}
    pageTitle={pageTitle}
>
    <div
        slot="intro"
        class="text-3xl md:text-4xl font-light font-sans leading-tight text-neutral-400/80"
    >
        {
            lang === "tr" ? (
                <>
                    <p class="mb-6">
                        Merhaba, ben{" "}
                        <span class="text-text font-medium">Bayram.</span>
                    </p>
                    <p>
                        <span class="text-text font-medium">Trabzon</span>'da
                        yaşayan,{" "}
                        <span class="text-text font-medium">yazılım</span>{" "}
                        geliştirici,{" "}
                        <span class="text-text font-medium">film</span> ve
                        <span class="text-text font-medium">oyun</span> tutkunu,
                        ara sıra{" "}
                        <span class="text-text font-medium">fotoğraf</span>{" "}
                        çeken biriyim. Gündüzleri
                        <span class="text-text font-medium">kod</span>{" "}
                        yazıyorum. Düşüncelerimi, zevklerimi ve ilgi alanlarımı
                        paylaştığım bir yer.
                    </p>
                </>
            ) : (
                <>
                    <p class="mb-6">
                        Hello, I'm{" "}
                        <span class="text-text font-medium">Bayram.</span>
                    </p>
                    <p>
                        Living in{" "}
                        <span class="text-text font-medium">Trabzon</span>,{" "}
                        <span class="text-text font-medium">software</span>{" "}
                        developer,{" "}
                        <span class="text-text font-medium">film</span> and
                        <span class="text-text font-medium">game</span>{" "}
                        enthusiast, occasional{" "}
                        <span class="text-text font-medium">photographer</span>.
                        I write <span class="text-text font-medium">code</span>{" "}
                        by day. A place where I share my thoughts, tastes, and
                        interests.
                    </p>
                </>
            )
        }
    </div>
</SimplePageLayout>
