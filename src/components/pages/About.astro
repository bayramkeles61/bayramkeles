---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, getRelativeLocaleUrl } from "../../i18n/utils";

interface Props {
    lang: "tr" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
    {
        key: "blog",
        label: t("nav.blog"),
        icon: "M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25",
        subLabel:
            lang === "tr"
                ? "düşüncelerim ve öğrendiklerim"
                : "thoughts and learnings",
    },
    {
        key: "projects",
        label: t("nav.projects"),
        icon: "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
        subLabel: lang === "tr" ? "GitHub'da yaptıklarım" : "my work on GitHub",
    },
    {
        key: "movies",
        label: t("nav.movies"),
        icon: "m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z",
        subLabel: lang === "tr" ? "izleyip beğendiklerim" : "favorites",
    },
    {
        key: "games",
        label: t("nav.games"),
        icon: "M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z",
    },
];
---

<BaseLayout title={t("footer.about")} description="Bayram Keleş.">
    <div class="mt-16 sm:mt-32">
        <div
            class="grid grid-cols-1 gap-y-16 lg:grid-cols-2 lg:grid-rows-[auto_1fr] lg:gap-y-12"
        >
            <!-- Photo Column -->
            <div class="lg:pl-20">
                <div class="max-w-xs px-2.5 lg:max-w-none">
                    <div class="avatar-large">
                        <div
                            class="w-full h-full rounded-[calc(1rem-3px)] bg-linear-to-br from-zinc-100 to-zinc-200 dark:from-zinc-800 dark:to-zinc-900 flex items-center justify-center text-6xl"
                        >
                            👋
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bio Column -->
            <div class="lg:order-first lg:row-span-2">
                <h1
                    class="text-3xl font-heading font-light leading-tight text-zinc-800 dark:text-zinc-100 sm:text-4xl"
                >
                    {
                        lang === "tr"
                            ? "Ben Bayram. İstanbul'da yaşıyorum, geleceği kodlamaya çalışıyorum."
                            : "I'm Bayram. I live in Istanbul, trying to code the future."
                    }
                </h1>
                <div
                    class="mt-6 space-y-7 text-base text-zinc-600 dark:text-zinc-400 leading-relaxed"
                >
                    <p>
                        {
                            lang === "tr"
                                ? "Merhaba! Ben Bayram. Yazılım geliştirici, film ve oyun tutkunu, ara sıra fotoğraf çeken biriyim."
                                : "Hello! I'm Bayram. I'm a software developer, movie and game enthusiast, and occasional photographer."
                        }
                    </p>
                    <p>
                        {
                            lang === "tr"
                                ? 'Bu siteyi neden yaptım? Çünkü LinkedIn gibi platformların yapaylığından bıktım. Herkes "profesyonel" görünmeye çalışırken, gerçek insanları görmek zorlaşıyor. Burada öyle bir endişem yok — sadece ben.'
                                : 'Why did I build this site? Because I got tired of the artificiality of platforms like LinkedIn. While everyone tries to look "professional", it gets harder to see real people. No such worry here — just me.'
                        }
                    </p>
                    <p>
                        {
                            lang === "tr"
                                ? "Gündüzleri kod yazıyorum. Akşamları film izler, oyun oynar, veya yeni bir şeyler öğrenmeye çalışırım. Bazen de sadece pencereden dışarı bakarım."
                                : "I write code by day. In the evenings, I watch movies, play games, or try to learn something new. Sometimes I just stare out the window."
                        }
                    </p>
                    <p>
                        {
                            lang === "tr"
                                ? "Burası benim dijital köşem. Düşüncelerimi, zevklerimi ve ilgi alanlarımı paylaştığım bir yer."
                                : "This is my digital corner. A place where I share my thoughts, tastes and interests."
                        }
                    </p>
                </div>
            </div>

            <!-- Social Links Column -->
            <div class="lg:pl-20">
                <div class="flex flex-col">
                    <a
                        href="https://github.com/bayramkeles"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-3 py-3 text-sm text-zinc-500 transition-colors hover:text-teal-500 dark:text-zinc-400 border-b border-zinc-100 dark:border-zinc-800/50"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-5 w-5 text-zinc-400 transition-colors group-hover:text-teal-500"
                        >
                            <path
                                fill-rule="evenodd"
                                clip-rule="evenodd"
                                d="M12 2C6.475 2 2 6.588 2 12.253c0 4.537 2.862 8.369 6.838 9.727.5.09.687-.218.687-.487 0-.243-.013-1.05-.013-1.91C7 20.059 6.35 18.957 6.15 18.38c-.113-.295-.6-1.205-1.025-1.448-.35-.192-.85-.667-.013-.68.788-.012 1.35.744 1.538 1.051.9 1.551 2.338 1.116 2.912.846.088-.666.35-1.115.638-1.371-2.225-.256-4.55-1.14-4.55-5.062 0-1.115.387-2.038 1.025-2.756-.1-.256-.45-1.307.1-2.717 0 0 .837-.269 2.75 1.051.8-.23 1.65-.346 2.5-.346.85 0 1.7.115 2.5.346 1.912-1.333 2.75-1.05 2.75-1.05.55 1.409.2 2.46.1 2.716.637.718 1.025 1.628 1.025 2.756 0 3.934-2.337 4.806-4.562 5.062.362.32.675.936.675 1.897 0 1.371-.013 2.473-.013 2.82 0 .268.188.589.688.486a10.039 10.039 0 0 0 4.932-3.74A10.447 10.447 0 0 0 22 12.253C22 6.588 17.525 2 12 2Z"
                            ></path>
                        </svg>
                        GitHub'da takip et
                    </a>
                    <a
                        href="mailto:info@bayramkeles.com"
                        class="flex items-center gap-3 py-3 text-sm text-zinc-500 transition-colors hover:text-teal-500 dark:text-zinc-400 border-b border-zinc-100 dark:border-zinc-800/50"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-5 w-5 text-zinc-400 transition-colors group-hover:text-teal-500"
                        >
                            <path
                                d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z"
                            ></path>
                            <path
                                d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z"
                            ></path>
                        </svg>
                        info@bayramkeles.com
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- What I'm Into Section -->
    <div class="mt-24">
        <h2
            class="text-xl font-medium tracking-tight text-zinc-900 dark:text-zinc-100 mb-6"
        >
            {lang === "tr" ? "nelerle ilgileniyorum" : "what i'm into"}
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {
                navLinks.map((link) => (
                    <a
                        href={getRelativeLocaleUrl(lang, link.key)}
                        class="group flex flex-col items-center justify-center gap-3 rounded-2xl border border-zinc-100 bg-zinc-50/50 p-6 transition-all hover:bg-white hover:shadow-lg hover:border-teal-500/20 dark:border-zinc-800/50 dark:bg-zinc-900/50 dark:hover:bg-zinc-900 dark:hover:border-zinc-700"
                    >
                        <div class="text-zinc-300 transition-colors group-hover:text-teal-500 dark:text-zinc-600">
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d={link.icon}
                                />
                            </svg>
                        </div>
                        <span class="font-medium text-zinc-900 dark:text-zinc-100">
                            {link.label}
                        </span>
                        <span class="text-xs text-zinc-400 dark:text-zinc-500 text-center">
                            {link.subLabel}
                        </span>
                    </a>
                ))
            }
        </div>
    </div>

    <!-- Tech Info -->
    <div class="mt-24 mb-16">
        <div class="h-px bg-zinc-100 dark:bg-zinc-800 w-full"></div>
        <p class="text-sm text-zinc-400 dark:text-zinc-600 mt-8">
            {lang === "tr" ? "Bu site" : "This site is built with"}
            <a
                href="https://astro.build"
                target="_blank"
                class="text-teal-500 hover:underline">Astro</a
            >
            {lang === "tr" ? "ile yapıldı. Kaynak kodu" : ". Source code is on"}
            <a
                href="https://github.com/bayramkeles/personal-website"
                target="_blank"
                class="text-teal-500 hover:underline">GitHub</a
            >.
        </p>
    </div>
</BaseLayout>
