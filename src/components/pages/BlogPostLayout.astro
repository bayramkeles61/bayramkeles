---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRelativeLocaleUrl } from "../../i18n/utils";

interface Props {
    lang: "tr" | "en";
    post: any;
}

const { lang, post } = Astro.props;

const backLink = getRelativeLocaleUrl(lang, "blog");
const backText = lang === "tr" ? "tüm yazılar" : "all posts";

const formattedDate = post.data.pubDate.toLocaleDateString(
    lang === "tr" ? "tr-TR" : "en-US",
    {
        year: "numeric",
        month: "long",
        day: "numeric",
    },
);
---

<BaseLayout title={post.data.title} description={post.data.description}>
    <div class="container-outer mt-16 sm:mt-32">
        <div class="container-outer-inner">
            <div class="container-inner">
                <div class="container-inner-content max-w-3xl">
                    <article>
                        <!-- Header -->
                        <header class="flex flex-col">
                            <a
                                href={backLink}
                                class="group mb-8 flex items-center text-sm font-medium text-text-muted transition hover:text-teal"
                            >
                                <svg
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    class="mr-2 h-4 w-4 stroke-current transition group-hover:-translate-x-0.5"
                                >
                                    <path
                                        d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
                                        stroke-width="1.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                </svg>
                                {backText}
                            </a>
                            <time
                                datetime={post.data.pubDate.toISOString()}
                                class="order-first flex items-center text-base text-text-muted"
                            >
                                <span
                                    class="h-4 w-0.5 rounded-full bg-border mr-3"
                                ></span>
                                {formattedDate}
                            </time>
                            <h1
                                class="mt-6 text-4xl font-bold tracking-tight text-text sm:text-5xl"
                            >
                                {post.data.title}
                            </h1>
                        </header>

                        <!-- Content -->
                        <div class="mt-8 prose">
                            <slot />
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
