---
import {
    getLangFromUrl,
    useTranslations,
    getRelativeLocaleUrl,
} from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import Sun from "@lucide/astro/icons/sun";
import Moon from "@lucide/astro/icons/moon";
import Menu from "@lucide/astro/icons/menu";
import X from "@lucide/astro/icons/x";

import House from "@lucide/astro/icons/house";
import Rocket from "@lucide/astro/icons/rocket";
import Film from "@lucide/astro/icons/film";

const navItems = [
    {
        href: getRelativeLocaleUrl(lang, ""),
        label: t("nav.home"),
        key: "1",
        icon: House,
    },
    // {
    //     href: getRelativeLocaleUrl(lang, "blog"),
    //     label: t("nav.blog"),
    //     key: "2",
    //     icon: BookOpen,
    // },
    {
        href: getRelativeLocaleUrl(lang, "projects"),
        label: t("nav.projects"),
        key: "2",
        icon: Rocket,
    },
    {
        href: getRelativeLocaleUrl(lang, "favorites"),
        label: t("nav.favorites"),
        key: "4",
        icon: Film,
    },
    // {
    //     href: getRelativeLocaleUrl(lang, "gallery"),
    //     label: t("nav.gallery"),
    //     key: "6",
    //     icon: Image,
    // },
];

const currentPath = Astro.url.pathname;
---

<header
    class="pointer-events-none sticky top-0 z-50 flex flex-none flex-col transition-all duration-300 transform"
    id="main-header"
>
    <div
        class="top-0 z-10 h-16 pt-6 px-10 flex items-center justify-between w-full"
    >
        <div class="relative flex items-center justify-between w-full">
            <!-- Desktop Navigation -->
            <div
                class="pointer-events-auto transition-all duration-300 bg-white border border-neutral-400/50 rounded-lg shadow dark:bg-zinc-900"
                id="nav-container"
            >
                <nav class="hidden md:block">
                    <ul class="flex items-center justify-center">
                        {
                            navItems.map((item) => (
                                <li class="h-full items-center justify-center">
                                    <a
                                        href={item.href}
                                        data-astro-prefetch="viewport"
                                        data-shortcut={item.key}
                                        class:list={[
                                            "relative flex items-center justify-center px-3 py-2 transition hover:text-black dark:hover:text-white text-lg",
                                            (currentPath.replace(/\/$/, "") ||
                                                "/") ===
                                                (item.href.replace(/\/$/, "") ||
                                                    "/") ||
                                            currentPath.startsWith(
                                                item.href + "/",
                                            )
                                                ? "text-black dark:text-white"
                                                : "text-zinc-500 dark:text-zinc-400",
                                        ]}
                                    >
                                        <item.icon class="size-4 mr-2" />
                                        <div class="first-letter:uppercase">
                                            {item.label}
                                        </div>
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </nav>

                <!-- Mobile Navigation Button -->
                <button
                    id="mobile-menu-button"
                    class="md:hidden flex rounded-full p-2 text-sm font-medium text-text"
                    aria-label={t("nav.menu")}
                >
                    <Menu class="h-5 w-5 stroke-current" />
                </button>
            </div>
            <!-- Theme Toggle -->
            <div
                class="flex justify-end md:flex-1 gap-4 transition-opacity duration-300"
                id="header-actions"
            >
                <div class="pointer-events-auto flex items-center">
                    <a
                        href={lang === "tr"
                            ? "/en" + (currentPath === "/" ? "" : currentPath)
                            : currentPath.replace(/^\/en/, "") || "/"}
                        class="text-sm font-medium text-text-muted hover:text-black dark:hover:text-white transition"
                    >
                        {lang === "tr" ? "TR" : "EN"}
                    </a>
                </div>
                <div
                    class="pointer-events-auto cursor-pointer flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded p-1"
                >
                    <button
                        id="theme-toggle"
                        class=""
                        aria-label="Tema değiştir"
                    >
                        <Sun id="sun-icon" class="size-5 hidden" />
                        <Moon id="moon-icon" class="size-5" />
                    </button>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-50 hidden">
    <div
        id="mobile-menu-backdrop"
        class="fixed inset-0 bg-zinc-800/40 dark:bg-black/80"
    >
    </div>
    <div
        class="fixed inset-x-4 top-8 z-50 rounded-3xl bg-white dark:bg-zinc-900 p-8 ring-1 ring-zinc-900/5 dark:ring-zinc-800"
    >
        <div class="flex flex-row-reverse items-center justify-between">
            <button
                id="mobile-menu-close"
                aria-label="Menüyü kapat"
                class="-m-1 p-1"
            >
                <X class="h-6 w-6 text-zinc-500 dark:text-zinc-400" />
            </button>
            <h2 class="text-sm font-medium text-zinc-600 dark:text-zinc-400">
                {t("nav.navigation")}
            </h2>
        </div>
        <nav class="mt-6">
            <ul
                class="-my-2 divide-y divide-zinc-100 text-base text-zinc-800 dark:divide-zinc-100/5 dark:text-zinc-300 list-none p-0"
            >
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                data-astro-prefetch="viewport"
                                class="flex items-center py-2"
                            >
                                <span class="text-black dark:text-white mr-2">
                                    {item.key}
                                </span>
                                <item.icon class="size-4 mr-2" />
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</div>

<script>
    function init() {
        // Theme toggle
        const themeToggle = document.getElementById("theme-toggle");
        const sunIcon = document.getElementById("sun-icon");
        const moonIcon = document.getElementById("moon-icon");

        const updateIcons = (isDark: boolean) => {
            if (isDark) {
                sunIcon?.classList.remove("hidden");
                moonIcon?.classList.add("hidden");
            } else {
                sunIcon?.classList.add("hidden");
                moonIcon?.classList.remove("hidden");
            }
        };

        // Scroll Behavior
        const headerActions = document.getElementById("header-actions");

        const handleScroll = () => {
            if (window.scrollY > 50) {
                headerActions?.classList.add(
                    "opacity-0",
                    "pointer-events-none",
                );
            } else {
                headerActions?.classList.remove(
                    "opacity-0",
                    "pointer-events-none",
                );
            }
        };

        window.addEventListener("scroll", handleScroll);

        // Initialize state
        // Initialize state based on current DOM (set by BaseLayout)
        const isDark = document.documentElement.classList.contains("dark");
        updateIcons(isDark);

        // Observer to update icons when class changes (e.g. system theme change)
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (
                    mutation.type === "attributes" &&
                    mutation.attributeName === "class"
                ) {
                    const isDark =
                        document.documentElement.classList.contains("dark");
                    updateIcons(isDark);
                }
            });
        });
        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
        });

        themeToggle?.addEventListener("click", () => {
            const isDark = document.documentElement.classList.toggle("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
            updateIcons(isDark);
        });

        // Mobile menu
        const mobileMenuButton = document.getElementById("mobile-menu-button");
        const mobileMenu = document.getElementById("mobile-menu");
        const mobileMenuClose = document.getElementById("mobile-menu-close");
        const mobileMenuBackdrop = document.getElementById(
            "mobile-menu-backdrop",
        );

        function openMobileMenu() {
            mobileMenu?.classList.remove("hidden");
            document.body.style.overflow = "hidden";
        }

        function closeMobileMenu() {
            mobileMenu?.classList.add("hidden");
            document.body.style.overflow = "";
        }

        mobileMenuButton?.addEventListener("click", openMobileMenu);
        mobileMenuClose?.addEventListener("click", closeMobileMenu);
        mobileMenuBackdrop?.addEventListener("click", closeMobileMenu);

        // Keyboard shortcuts for navigation
        const handleKeydown = (e: KeyboardEvent) => {
            // Ignore if user is typing in an input field
            if (
                e.target instanceof HTMLInputElement ||
                e.target instanceof HTMLTextAreaElement ||
                e.ctrlKey ||
                e.metaKey ||
                e.altKey
            ) {
                return;
            }

            // Close mobile menu on Escape
            if (e.key === "Escape") {
                closeMobileMenu();
                return;
            }

            const key = e.key;
            if (key >= "1" && key <= "6") {
                const link = document.querySelector(
                    `a[data-shortcut="${key}"]`,
                ) as HTMLAnchorElement;
                if (link) {
                    link.click();
                }
            }
        };

        document.addEventListener("keydown", handleKeydown);

        // Cleanup function to remove event listeners before swapping (optional but good practice)
        // However, Astro's View Transitions automatically handles most cleanup when DOM elements are removed.
        // For 'document' listeners, we should clean them up.
        document.addEventListener(
            "astro:before-swap",
            () => {
                document.removeEventListener("keydown", handleKeydown);
            },
            { once: true },
        );
    }

    // Run on initial load
    init();

    // Run on view transition navigation
    document.addEventListener("astro:after-swap", init);
</script>
